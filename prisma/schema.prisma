generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  ADMIN
}

enum GameStatus {
  AVAILABLE
  BORROWED
}

enum LoanStatus {
  ACTIVE
  RETURNED
}

enum LoanRequestType {
  BORROW
  RETURN
}

enum LoanRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanPhotoType {
  BORROW
  RETURN
}

enum LoanActivityType {
  BORROW
  RETURN
}

enum MeetupActivityType {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum RatingPlayedStatus {
  VERIFIED
  SELF_REPORTED
  UNVERIFIED
}

enum NotificationType {
  LOAN_BORROWED
  RETURN_REQUESTED
  LOAN_OVERDUE
}

enum NotificationChannel {
  DISCORD
}

enum NotificationStatus {
  SENT
  FAILED
}

model User {
  id                   String              @id @default(cuid())
  loginId              String              @unique
  name                 String
  studentId            String?
  passwordHash         String
  mustChangePassword   Boolean             @default(false)
  role                 UserRole            @default(MEMBER)
  createdAt            DateTime            @default(now())
  loans                Loan[]
  loanRequests         LoanRequest[]       @relation("LoanRequestRequester")
  reviewedLoanRequests LoanRequest[]       @relation("LoanRequestReviewer")
  ratings              GameRating[]
  meetups              Meetup[]
  participants         MeetupParticipant[]
  sessions             Session[]

  @@index([loginId])
  @@index([studentId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model Game {
  id           String        @id @default(cuid())
  title        String
  players      String?
  bestPlayers  String?
  playTime     String?
  quantity     Int?
  note         String?
  genre        String?
  isPresent    Boolean?
  weight       String?
  infoUrl      String?
  status       GameStatus    @default(AVAILABLE)
  createdAt    DateTime      @default(now())
  loans        Loan[]
  loanRequests LoanRequest[]
  ratings      GameRating[]
  meetups      Meetup[]

  @@index([status])
  @@index([title])
}

model GameRating {
  id           String              @id @default(cuid())
  gameId       String
  userId       String
  score        Float
  playedStatus RatingPlayedStatus  @default(UNVERIFIED)
  trustWeight  Float               @default(0.5)
  reasonTags   String[]
  comment      String?
  isHidden     Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  game         Game                @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([userId])
  @@index([gameId])
  @@index([playedStatus])
  @@index([isHidden])
}

model GameTable {
  id        String   @id @default(cuid())
  name      String   @unique
  capacity  Int
  createdAt DateTime @default(now())
  meetups   Meetup[]
}

model Loan {
  id         String        @id @default(cuid())
  gameId     String
  borrowerId String
  status     LoanStatus    @default(ACTIVE)
  borrowedAt DateTime      @default(now())
  dueAt      DateTime
  returnedAt DateTime?
  game       Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  borrower   User          @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  requests   LoanRequest[]
  photos     LoanPhoto[]

  @@index([status])
  @@index([borrowerId])
  @@index([gameId])
}

model LoanRequest {
  id          String            @id @default(cuid())
  type        LoanRequestType
  status      LoanRequestStatus @default(PENDING)
  gameId      String
  loanId      String?
  requesterId String
  reviewerId  String?
  requestedAt DateTime          @default(now())
  reviewedAt  DateTime?
  game        Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  loan        Loan?             @relation(fields: [loanId], references: [id], onDelete: Cascade)
  requester   User              @relation("LoanRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer    User?             @relation("LoanRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  photos      LoanPhoto[]

  @@index([status])
  @@index([type])
  @@index([gameId])
  @@index([loanId])
  @@index([requesterId])
  @@index([reviewerId])
}

model LoanPhoto {
  id            String        @id @default(cuid())
  type          LoanPhotoType
  loanId        String
  loanRequestId String?
  contentType   String
  size          Int
  data          Bytes
  createdAt     DateTime      @default(now())
  loan          Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  loanRequest   LoanRequest?  @relation(fields: [loanRequestId], references: [id], onDelete: SetNull)

  @@index([loanId])
  @@index([loanRequestId])
  @@index([type])
}

model LoanActivityLog {
  id              String           @id @default(cuid())
  type            LoanActivityType
  loanId          String?
  gameId          String?
  gameTitle       String
  borrowerId      String?
  borrowerName    String
  borrowerLoginId String?
  borrowerStudentId String?
  occurredAt      DateTime
  dueAt           DateTime?
  createdAt       DateTime         @default(now())

  @@index([type])
  @@index([occurredAt])
  @@index([gameId])
  @@index([borrowerId])
}

model Meetup {
  id           String              @id @default(cuid())
  title        String
  description  String?
  startsAt     DateTime
  maxPeople    Int
  createdAt    DateTime            @default(now())
  hostId       String
  gameId       String?
  tableId      String
  host         User                @relation(fields: [hostId], references: [id], onDelete: Cascade)
  game         Game?               @relation(fields: [gameId], references: [id], onDelete: SetNull)
  table        GameTable           @relation(fields: [tableId], references: [id], onDelete: Restrict)
  participants MeetupParticipant[]

  @@index([startsAt])
  @@index([hostId])
  @@index([tableId])
}

model MeetupParticipant {
  id        String   @id @default(cuid())
  meetupId  String
  userId    String
  createdAt DateTime @default(now())
  meetup    Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetupId, userId])
  @@index([userId])
}

model MeetupActivityLog {
  id           String             @id @default(cuid())
  type         MeetupActivityType
  meetupId     String?
  title        String
  description  String?
  startsAt     DateTime
  maxPeople    Int
  gameId       String?
  gameTitle    String?
  tableId      String?
  tableName    String?
  hostId       String?
  hostName     String
  hostLoginId  String?
  participants Json
  participantCount Int
  occurredAt   DateTime
  createdAt    DateTime           @default(now())

  @@index([type])
  @@index([startsAt])
  @@index([occurredAt])
  @@index([gameId])
  @@index([hostId])
}

model NotificationLog {
  id            String              @id @default(cuid())
  type          NotificationType
  channel       NotificationChannel
  status        NotificationStatus
  dedupeKey     String              @unique
  loanId        String?
  loanRequestId String?
  userId        String?
  title         String
  message       String
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([loanId])
  @@index([loanRequestId])
  @@index([userId])
  @@index([createdAt])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  isActive    Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([publishedAt])
}

model GeneralActivityLog {
  id              String   @id @default(cuid())
  category        String
  action          String
  actorId         String?
  actorName       String?
  actorLoginId    String?
  actorRole       String?
  targetType      String?
  targetId        String?
  targetName      String?
  message         String
  metadata        Json?
  occurredAt      DateTime
  createdAt       DateTime @default(now())

  @@index([category])
  @@index([action])
  @@index([actorId])
  @@index([targetType])
  @@index([targetId])
  @@index([occurredAt])
}
